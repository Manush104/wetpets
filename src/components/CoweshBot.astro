---
---
<div id="cowesh-bot" class="cowesh-wrapper">
  <!-- Chat Window -->
  <div id="cowesh-window" class="cowesh-window hidden">
    <div class="cowesh-header">
      <div class="cowesh-title">
        <span class="cowesh-avatar">🐠</span>
        <div>
          <h4>Cowesh</h4>
          <small>Wet Pets AI Assistant</small>
        </div>
      </div>
      <button id="cowesh-close" class="cowesh-close" aria-label="Close chat">×</button>
    </div>
    
    <div id="cowesh-messages" class="cowesh-messages">
      <div class="message bot">
        <div class="message-content">Hello! I'm Cowesh. Ask me anything about ornamental fish, aquariums, or our products!</div>
      </div>
    </div>
    
    <div class="cowesh-input-area">
      <input type="text" id="cowesh-input" placeholder="Type your question..." autocomplete="off" />
      <button id="cowesh-send" aria-label="Send message">
        <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
      </button>
    </div>
  </div>

  <!-- Toggle Button -->
  <button id="cowesh-toggle" class="cowesh-toggle" aria-label="Chat with Cowesh">
    <span class="cowesh-icon">💬</span>
  </button>
</div>

<style>
  .cowesh-wrapper {
    position: fixed;
    bottom: var(--sp-6);
    left: var(--sp-6); /* Bottom left to avoid WhatsApp float on right */
    z-index: 100;
    font-family: var(--font-base);
  }

  /* Toggle Button */
  .cowesh-toggle {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-color: var(--clr-primary);
    color: var(--clr-white);
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }
  .cowesh-toggle:hover {
    transform: scale(1.1);
    background-color: var(--clr-primary-light);
  }

  /* Chat Window */
  .cowesh-window {
    position: absolute;
    bottom: 70px;
    left: 0;
    width: 320px;
    height: 400px;
    background-color: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 10px 25px rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform-origin: bottom left;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.3s ease;
  }

  .cowesh-window.hidden {
    opacity: 0;
    transform: scale(0);
    pointer-events: none;
  }

  /* Header */
  .cowesh-header {
    background-color: var(--clr-surface-2);
    padding: var(--sp-3);
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--clr-border);
  }
  .cowesh-title {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .cowesh-title h4 {
    margin: 0;
    font-size: var(--fs-base);
    color: var(--clr-text);
  }
  .cowesh-title small {
    color: var(--clr-text-muted);
    font-size: var(--fs-xs);
  }
  .cowesh-avatar {
    font-size: 1.5rem;
  }
  .cowesh-close {
    background: none;
    border: none;
    color: var(--clr-text-muted);
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0 var(--sp-1);
    transition: color 0.2s;
  }
  .cowesh-close:hover {
    color: var(--clr-text);
  }

  /* Messages Area */
  .cowesh-messages {
    flex: 1;
    padding: var(--sp-3);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    background-color: var(--clr-bg);
  }
  
  .message {
    display: flex;
    max-width: 85%;
  }
  .message.user {
    align-self: flex-end;
  }
  .message.bot {
    align-self: flex-start;
  }
  .message-content {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-md);
    font-size: var(--fs-sm);
    line-height: 1.4;
  }
  .message.user .message-content {
    background-color: var(--clr-primary);
    color: var(--clr-white);
    border-bottom-right-radius: 4px;
  }
  .message.bot .message-content {
    background-color: var(--clr-surface-2);
    color: var(--clr-text);
    border-bottom-left-radius: 4px;
    border: 1px solid var(--clr-border);
  }

  /* Typing indicator */
  .typing-indicator {
    display: flex;
    gap: 4px;
    padding: 8px 12px;
    background-color: var(--clr-surface-2);
    border-radius: var(--radius-md);
    width: max-content;
    align-self: flex-start;
  }
  .typing-dot {
    width: 6px;
    height: 6px;
    background-color: var(--clr-text-muted);
    border-radius: 50%;
    animation: typing 1.4s infinite ease-in-out;
  }
  .typing-dot:nth-child(1) { animation-delay: 0s; }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typing {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  /* Input Area */
  .cowesh-input-area {
    display: flex;
    padding: var(--sp-2);
    background-color: var(--clr-surface);
    border-top: 1px solid var(--clr-border);
    gap: var(--sp-2);
  }
  .cowesh-input-area input {
    flex: 1;
    background-color: var(--clr-bg);
    border: 1px solid var(--clr-border);
    color: var(--clr-text);
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-full);
    outline: none;
    font-size: var(--fs-sm);
    transition: border-color 0.2s;
  }
  .cowesh-input-area input:focus {
    border-color: var(--clr-primary);
  }
  .cowesh-input-area button {
    background-color: var(--clr-primary);
    color: var(--clr-white);
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s;
  }
  .cowesh-input-area button:hover {
    background-color: var(--clr-primary-light);
  }
  .cowesh-input-area button:disabled {
    background-color: var(--clr-border);
    cursor: not-allowed;
  }

  @media (max-width: 500px) {
    .cowesh-window {
      width: calc(100vw - var(--sp-12));
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtn = document.getElementById('cowesh-toggle');
    const closeBtn = document.getElementById('cowesh-close');
    const windowEl = document.getElementById('cowesh-window');
    const inputEl = document.getElementById('cowesh-input') as HTMLInputElement;
    const sendBtn = document.getElementById('cowesh-send') as HTMLButtonElement;
    const messagesEl = document.getElementById('cowesh-messages');

    if (!toggleBtn || !windowEl || !inputEl || !sendBtn || !messagesEl) return;

    // Toggle window
    toggleBtn.addEventListener('click', () => {
      windowEl.classList.remove('hidden');
      inputEl.focus();
    });

    closeBtn?.addEventListener('click', () => {
      windowEl.classList.add('hidden');
    });

    // Auto scroll to bottom
    const scrollToBottom = () => {
      messagesEl.scrollTop = messagesEl.scrollHeight;
    };

    // Add a message to UI
    const appendMessage = (text: string, sender: 'user' | 'bot') => {
      const msgDiv = document.createElement('div');
      msgDiv.className = `message ${sender}`;
      
      const contentDiv = document.createElement('div');
      contentDiv.className = 'message-content';
      contentDiv.textContent = text;
      
      msgDiv.appendChild(contentDiv);
      messagesEl.appendChild(msgDiv);
      scrollToBottom();
    };

    // Show/hide typing indicator
    let typingIndicator: HTMLElement | null = null;
    const showTyping = () => {
      typingIndicator = document.createElement('div');
      typingIndicator.className = 'typing-indicator';
      typingIndicator.innerHTML = '<div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>';
      messagesEl.appendChild(typingIndicator);
      scrollToBottom();
    };
    const hideTyping = () => {
      if (typingIndicator) {
        typingIndicator.remove();
        typingIndicator = null;
      }
    };

    // Handle sending message
    const sendMessage = async () => {
      const text = inputEl.value.trim();
      if (!text) return;

      // Disable input while processing
      inputEl.value = '';
      inputEl.disabled = true;
      sendBtn.disabled = true;

      appendMessage(text, 'user');
      showTyping();

      try {
        const response = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: text })
        });

        const data = await response.json();
        hideTyping();

        if (response.ok && data.reply) {
          appendMessage(data.reply, 'bot');
        } else {
          appendMessage("Sorry, I'm having trouble connecting right now.", 'bot');
          console.error('Chat error:', data.error);
        }
      } catch (err) {
        hideTyping();
        appendMessage("Sorry, an error occurred.", 'bot');
        console.error(err);
      } finally {
        inputEl.disabled = false;
        sendBtn.disabled = false;
        inputEl.focus();
      }
    };

    sendBtn.addEventListener('click', sendMessage);
    inputEl.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        sendMessage();
      }
    });
  });
</script>
